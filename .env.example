# hermes-codex-bridge env sample
#
# Rule: do not copy code defaults into runtime env. Leave a variable unset unless
# you are enabling a feature, providing a secret/id, or overriding a default.
# For normal installs prefer:
#   scripts/install-hermes-stack.sh --webhook --restart --non-interactive --channel <fallback-channel-id>

# -----------------------------------------------------------------------------
# 1) Local bridge only — no env required
# -----------------------------------------------------------------------------
# These are built-in defaults; keep them unset unless you are changing them:
# HOST=127.0.0.1
# PORT=3037
# BRIDGE_PUBLIC_URL=http://127.0.0.1:3037
# BRIDGE_STATE_ROOT=~/.local/state/hermes-codex-bridge
# BRIDGE_HERMES_PROJECT_CHANNEL_MAP=~/.config/hermes-codex-bridge/project-channels.json

# Set only when the bridge is reachable from Docker/LAN/reverse proxy/public.
# Requests other than GET /health must send: Authorization: Bearer <token>
# BRIDGE_TOKEN=<random-long-token>

# -----------------------------------------------------------------------------
# 2) Recommended Discord notification setup
# -----------------------------------------------------------------------------
# Required to enable the Hermes Gateway webhook sink:
# BRIDGE_HERMES_WEBHOOK_ENABLED=true
# BRIDGE_HERMES_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/codex-bridge
# BRIDGE_HERMES_WEBHOOK_SECRET=<same-as-Hermes-WEBHOOK_SECRET>
# BRIDGE_HERMES_DEFAULT_CHANNEL_ID=<fallback-discord-channel-id>

# Required for deterministic project channel lookup/create and per-session threads:
# BRIDGE_DISCORD_BOT_TOKEN=<discord-bot-token>
# BRIDGE_DISCORD_GUILD_ID=<discord-guild-id>
# BRIDGE_DISCORD_FAST_EVENTS_ENABLED=true
# BRIDGE_DISCORD_AUTO_CREATE_THREADS=true
# BRIDGE_NOTIFY_INCLUDE_UNMAPPED_CODEX_LOGS=true

# Recommended when the bridge should add newly mapped project channels to Hermes
# Gateway's Discord allowlist. The config path and restart command have defaults.
# BRIDGE_HERMES_ALLOWLIST=true
# BRIDGE_HERMES_CONFIG=~/.hermes/config.yaml
# BRIDGE_HERMES_RESTART_CMD=systemctl --user restart --no-block hermes-gateway.service

# Optional: mention users only on the initial SessionStart alert.
# BRIDGE_DISCORD_MENTION_USERS=<discord-user-id>[,<discord-user-id>...]

# Optional: post explicit delivery-dead alerts to the operations channel.
# Uses the same BRIDGE_DISCORD_BOT_TOKEN; no separate token is required.
# DISCORD_ALERT_CHANNEL_ID=123456789012345678

# -----------------------------------------------------------------------------
# 3) Common non-default overrides
# -----------------------------------------------------------------------------
# Bind outside localhost only with BRIDGE_TOKEN set.
# HOST=0.0.0.0
# PORT=3037
# BRIDGE_PUBLIC_URL=https://bridge.example.com

# Use a fixed scan root only for non-tmux setups. Normal installs discover live
# tmux/Codex project roots and recent run roots automatically.
# PROJECT_ROOT=/path/to/fixed-codex-project

# Summary mode is opt-in. Default is direct FinalAnswer delivery.
# BRIDGE_HERMES_NOTIFICATION_MODE=summary

# Poll intervals are already fast by default: Hermes 250ms, Discord fast-path
# 100ms. Increase only to reduce CPU/API calls, accepting slower alerts.
# BRIDGE_HERMES_WEBHOOK_INTERVAL_MS=3000
# BRIDGE_NOTIFY_INTERVAL_MS=3000

# Advanced defaults usually left unset:
# Optional Codex reasoning effort for sessions started with codex-new.
# CODEX_EFFORT=high
# BRIDGE_HERMES_WEBHOOK_EVENT_TYPES=AskPermission,FinalAnswer
# BRIDGE_NOTIFY_EVENT_TYPES=SessionStart,SessionLinked,SessionEnd,CommandSubmitted
# BRIDGE_NOTIFY_DELIVERY_SINK=discord-fast
# BRIDGE_FINAL_BLOCK=true
# BRIDGE_FINAL_WAIT_MS=10000
# BRIDGE_FINAL_SINK=hermes
# DISCORD_POST_TIMEOUT_MS=3000
# DISCORD_429_MAX_WAIT_MS=1000
# BRIDGE_CODEX_CWD_ATTACH_SCAN_LIMIT=30
